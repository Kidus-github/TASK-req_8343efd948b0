{
  "name": "cleanwave-offline-audio-prep",
  "version": "1.0.0",
  "description": "CleanWave Offline Audio Prep - browser-based batch audio editor (Svelte + TypeScript SPA)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "prepare-models": "node scripts/prepare-face-models.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/component",
    "test:flow": "vitest run tests/flow",
    "test:browser": "playwright test",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@testing-library/svelte": "^4.1.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.14.9",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.1.0",
    "svelte": "^4.2.18",
    "svelte-check": "^3.8.4",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "face-api.js": "^0.22.2"
  }
}
